# Add your api key for OpenRouter and OpenAI
export OPENROUTER_API_KEY=
export OPENAI_API_KEY=
# Add your Google AI Studio key to use Gemini natively (free tier available)
export GEMINI_API_KEY=
# Add your Anthropic API key to use Claude models natively
export ANTHROPIC_API_KEY=
# Local models via ollama require no API key — just run `ollama serve` before experiments